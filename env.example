# copy this file to .env and fill in your keys
# .env is gitignored; env.example is checked in

# ---------- LLM (required) ----------
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---------- alpaca paper trading (required for execution + options agents) ----------
# https://alpaca.markets/ -> paper trading. Run TWO accounts in parallel, e.g.
#   account 1 = conservative book (no crypto)  ->  daily_rebalance ... --account 1
#   account 2 = aggressive book (crypto-armed) ->  daily_rebalance ... --account 2
# Account 1 (default):
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Account 2 (optional second paper account; leave blank to disable):
ALPACA_API_KEY_2=
ALPACA_API_SECRET_2=
# Account 3 (optional third paper account — OPTIONS / LEAPS book; leave blank to disable):
#   account 3 = defined-risk index LEAPS  ->  daily_rebalance ... --account 3
#   NOTE: enable OPTIONS TRADING on this Alpaca paper account or option orders fail.
ALPACA_API_KEY_3=
ALPACA_API_SECRET_3=

# ---------- embeddings (required for regime store) ----------
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ---------- free supplementary market data (optional but recommended) ----------
# finnhub:  real-time quotes, news, sentiment, earnings calendar
#           https://finnhub.io/   (free key, 60 req/min)
FINNHUB_API_KEY=

# fred (Federal Reserve Economic Data): VIX, treasury yields, USD index, etc.
#           https://fred.stlouisfed.org/docs/api/api_key.html  (free, generous)
FRED_API_KEY=

# ---------- RAG Vault sentiment signal API (optional; for --sentiment-overlay) ----------
# The S&P 500 RAG Vault service (separate repo) serves per-ticker LONG/SHORT/FLAT
# verdicts blending Claude sentiment + supplier lead-lag + 8-K event drift.
# Start it with: uvicorn sp500_vault.api:app --host 0.0.0.0 --port 8000
# Then run the rebalancer with --sentiment-overlay. See SIGNAL_API.md.
SIGNAL_API_URL=http://127.0.0.1:8000
SIGNAL_API_TIMEOUT=5
SIGNAL_HORIZON=5
SIGNAL_TAU=0.5

# ---------- optional overrides ----------
# defaults to C:\Users\pcagm\Downloads\StockData if unset
# DATA_DIR=
