# copy this file to .env and fill in your keys
# .env is gitignored; env.example is checked in

# ---------- LLM (required) ----------
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---------- alpaca paper trading (required for execution + options agents) ----------
# https://alpaca.markets/ -> paper trading
ALPACA_API_KEY=
ALPACA_API_SECRET=

# ---------- embeddings (required for regime store) ----------
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ---------- free supplementary market data (optional but recommended) ----------
# finnhub:  real-time quotes, news, sentiment, earnings calendar
#           https://finnhub.io/   (free key, 60 req/min)
FINNHUB_API_KEY=

# fred (Federal Reserve Economic Data): VIX, treasury yields, USD index, etc.
#           https://fred.stlouisfed.org/docs/api/api_key.html  (free, generous)
FRED_API_KEY=

# ---------- optional overrides ----------
# defaults to C:\Users\pcagm\Downloads\StockData if unset
# DATA_DIR=
